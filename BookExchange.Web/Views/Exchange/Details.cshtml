@model ExchangeDetailsViewModel
@{
    ViewData["Title"] = $"Заявка #{Model.Id}";
    var statusClass = Model.Status switch
    {
        ExchangeStatus.Pending => "status-pill--pending",
        ExchangeStatus.Accepted => "status-pill--accepted",
        ExchangeStatus.Completed => "status-pill--completed",
        ExchangeStatus.Rejected => "status-pill--rejected",
        ExchangeStatus.Cancelled => "status-pill--cancelled",
        _ => "",
    };
    var other = Model.CurrentUserId == Model.Sender.Id ? Model.Receiver : Model.Sender;
}

<section class="page-hero page-hero--green">
    <div class="page-hero__inner">
        <a href="javascript:history.back()" class="page-hero__back">
            <svg class="icon"><use href="#i-arrow-left"/></svg> Назад
        </a>
        <div class="page-hero__row">
            <div>
                <h1>Обмен #@Model.Id</h1>
                <p>c @other.Name</p>
            </div>
            <span class="status-pill status-pill--hero @statusClass">
                <span class="status-pill__dot"></span>
                @Model.StatusLabel
            </span>
        </div>
    </div>
</section>

<section class="section">
    <div class="exchange-detail-layout">
        <div class="panel chat-panel">
            <div class="chat-panel__head">
                @if (!string.IsNullOrEmpty(other.Avatar))
                {
                    <img src="@other.Avatar" class="avatar" alt="@other.Name" />
                }
                else
                {
                    <span class="avatar" style="display:grid;place-items:center;background:var(--forest-soft);color:var(--forest);font-weight:700;">@(other.Name.Substring(0, 1).ToUpper())</span>
                }
                <div class="grow">
                    <strong>@other.Name</strong>
                    <div class="text-muted text-sm">Обсуждение обмена</div>
                </div>
            </div>
            <div id="chatMessages" class="chat-messages"
                 data-exchange-id="@Model.Id"
                 data-current-user="@Model.CurrentUserId">
                @if (Model.Messages.Count == 0)
                {
                    <div class="empty" style="margin:auto;border:none;background:transparent;">
                        <svg class="icon icon-xl"><use href="#i-chat"/></svg>
                        <p class="text-muted">Пока нет сообщений. Напиши первым!</p>
                    </div>
                }
                else
                {
                    foreach (var m in Model.Messages)
                    {
                        <div class="chat-message @(m.SenderId == Model.CurrentUserId ? "chat-message--own" : "")">
                            @if (!string.IsNullOrEmpty(m.SenderAvatar))
                            {
                                <img src="@m.SenderAvatar" class="avatar avatar-sm" alt="" />
                            }
                            <div class="chat-bubble">
                                <div class="chat-text">@m.Text</div>
                                <small>@m.SentAt.ToLocalTime().ToString("HH:mm")</small>
                            </div>
                        </div>
                    }
                }
            </div>
            <form id="chatForm" class="chat-form">
                <input type="text" id="chatInput" placeholder="Напишите сообщение..." maxlength="1000" autocomplete="off" />
                <button type="submit" class="btn btn-primary btn-icon" aria-label="Отправить">
                    <svg class="icon"><use href="#i-arrow-right"/></svg>
                </button>
            </form>
        </div>

        <aside class="exchange-detail-aside">
            <div class="panel">
                <h3 class="panel__title"><svg class="icon" style="color:var(--forest);"><use href="#i-check"/></svg> Вы получаете</h3>
                <div class="trade-book">
                    @if (!string.IsNullOrEmpty(Model.BookRequested?.CoverImagePath))
                    {
                        <img src="@Model.BookRequested.CoverImagePath" alt="@Model.BookRequested.Title" />
                    }
                    else
                    {
                        <div class="trade-book__placeholder"><svg class="icon icon-xl"><use href="#i-book"/></svg></div>
                    }
                    <div>
                        <strong>@Model.BookRequested?.Title</strong>
                        <p class="text-muted text-sm">@Model.BookRequested?.Author</p>
                        <span class="chip chip--ok">@Model.BookRequested?.ConditionLabel</span>
                    </div>
                </div>
            </div>

            <div class="panel">
                <h3 class="panel__title"><svg class="icon" style="color:var(--terracotta);"><use href="#i-swap"/></svg> Вы отдаёте</h3>
                @if (Model.BookOffered != null)
                {
                    <div class="trade-book">
                        @if (!string.IsNullOrEmpty(Model.BookOffered.CoverImagePath))
                        {
                            <img src="@Model.BookOffered.CoverImagePath" alt="@Model.BookOffered.Title" />
                        }
                        else
                        {
                            <div class="trade-book__placeholder"><svg class="icon icon-xl"><use href="#i-book"/></svg></div>
                        }
                        <div>
                            <strong>@Model.BookOffered.Title</strong>
                            <p class="text-muted text-sm">@Model.BookOffered.Author</p>
                            <span class="chip chip--ok">@Model.BookOffered.ConditionLabel</span>
                        </div>
                    </div>
                }
                else
                {
                    <div class="trade-book trade-book--gift">
                        <div class="trade-book__placeholder trade-book__placeholder--gift">
                            <svg class="icon icon-xl"><use href="#i-heart"/></svg>
                        </div>
                        <div>
                            <strong>Безвозмездно</strong>
                            <p class="text-muted text-sm">Передача в дар</p>
                        </div>
                    </div>
                }
            </div>

            @if (Model.CanAccept || Model.CanReject || Model.CanCancel || Model.CanComplete || Model.CanLeaveReview)
            {
                <div class="panel">
                    <h3 class="panel__title">Действия</h3>
                    <div class="flex-col gap-2">
                        @if (Model.CanAccept)
                        {
                            <form asp-action="Accept" method="post">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@Model.Id" />
                                <button class="btn btn-primary w-full"><svg class="icon"><use href="#i-check"/></svg> Принять обмен</button>
                            </form>
                        }
                        @if (Model.CanReject)
                        {
                            <form asp-action="Reject" method="post">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@Model.Id" />
                                <button class="btn btn-danger w-full"><svg class="icon"><use href="#i-x"/></svg> Отклонить</button>
                            </form>
                        }
                        @if (Model.CanCancel)
                        {
                            <form asp-action="Cancel" method="post">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@Model.Id" />
                                <button class="btn btn-outline w-full"><svg class="icon"><use href="#i-x"/></svg> Отменить</button>
                            </form>
                        }
                        @if (Model.CanComplete)
                        {
                            <form asp-action="Complete" method="post">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@Model.Id" />
                                <button class="btn btn-accent w-full"><svg class="icon"><use href="#i-swap"/></svg> Завершить обмен</button>
                            </form>
                        }
                        @if (Model.CanLeaveReview)
                        {
                            <a asp-action="LeaveReview" asp-route-id="@Model.Id" class="btn btn-accent w-full">
                                <svg class="icon"><use href="#i-star"/></svg> Оставить отзыв
                            </a>
                        }
                    </div>
                </div>
            }
        </aside>
    </div>
</section>

@section Scripts {
    <script>
        (async () => {
            const box = document.getElementById('chatMessages');
            const exchangeId = parseInt(box.dataset.exchangeId);
            const currentUserId = box.dataset.currentUser;
            box.scrollTop = box.scrollHeight;

            const conn = new signalR.HubConnectionBuilder().withUrl('/hubs/chat').withAutomaticReconnect().build();

            conn.on('ReceiveMessage', m => {
                const empty = box.querySelector('.empty');
                if (empty) empty.remove();
                const el = document.createElement('div');
                el.className = 'chat-message' + (m.senderId === currentUserId ? ' chat-message--own' : '');
                const avatar = m.senderAvatar ? `<img src="${m.senderAvatar}" class="avatar avatar-sm" alt=""/>` : '';
                const d = new Date(m.sentAt);
                const time = d.toTimeString().slice(0,5);
                el.innerHTML = `${avatar}<div class="chat-bubble"><div class="chat-text"></div><small>${time}</small></div>`;
                el.querySelector('.chat-text').textContent = m.text;
                box.appendChild(el);
                box.scrollTop = box.scrollHeight;
            });

            try {
                await conn.start();
                await conn.invoke('JoinGroup', exchangeId);
            } catch (e) { console.error('Chat connect failed', e); }

            document.getElementById('chatForm').addEventListener('submit', async e => {
                e.preventDefault();
                const input = document.getElementById('chatInput');
                const text = input.value.trim();
                if (!text) return;
                try {
                    await conn.invoke('SendMessage', exchangeId, text);
                    input.value = '';
                } catch (err) { console.error(err); }
            });
        })();
    </script>
}
