@model CreateExchangeViewModel
@{ ViewData["Title"] = "Предложить обмен"; }

<section class="page-hero page-hero--green">
    <div class="page-hero__inner">
        <a asp-controller="Book" asp-action="Details" asp-route-id="@Model.BookRequestedId" class="page-hero__back">
            <svg class="icon"><use href="#i-arrow-left"/></svg> Назад к книге
        </a>
        <h1>Создание обмена</h1>
        <p>Выберите книгу, которую хотите предложить взамен</p>
    </div>
</section>

<section class="section">
    <form asp-action="Create" asp-route-bookId="@Model.BookRequestedId" method="post" class="exchange-layout">
        @Html.AntiForgeryToken()

        <div class="exchange-main">
            @if (Model.BookRequested != null)
            {
                <div class="panel">
                    <h2 class="panel__title">Вы получите</h2>
                    <div class="target-book">
                        @if (!string.IsNullOrEmpty(Model.BookRequested.CoverImagePath))
                        {
                            <img src="@Model.BookRequested.CoverImagePath" alt="@Model.BookRequested.Title" class="target-book__cover" />
                        }
                        else
                        {
                            <div class="target-book__cover book-card__cover-placeholder">
                                <svg class="icon icon-xl"><use href="#i-book"/></svg>
                            </div>
                        }
                        <div class="target-book__info">
                            <h3>@Model.BookRequested.Title</h3>
                            <p class="text-muted">@Model.BookRequested.Author</p>
                            <span class="genre-pill genre-pill--soft">@Model.BookRequested.Genre</span>
                        </div>
                    </div>
                </div>
            }

            <div class="panel">
                <h2 class="panel__title">Ваши книги (@Model.MyAvailableBooks.Count @(Model.MyAvailableBooks.Count == 1 ? "доступна" : "доступно"))</h2>

                @if (Model.MyAvailableBooks.Count == 0)
                {
                    <div class="empty">
                        <svg class="icon icon-xl"><use href="#i-book"/></svg>
                        <p>У вас нет доступных книг для обмена.</p>
                        <a asp-controller="Book" asp-action="Create" class="btn btn-primary mt-2">
                            <svg class="icon"><use href="#i-plus"/></svg> Добавить книгу
                        </a>
                    </div>
                }
                else
                {
                    <div class="offer-list">
                        <label class="offer-card">
                            <input type="radio" name="selectedOfferedBookId" value="" checked />
                            <span class="offer-card__check"><svg class="icon"><use href="#i-check"/></svg></span>
                            <div class="offer-card__placeholder">
                                <svg class="icon"><use href="#i-heart"/></svg>
                            </div>
                            <div class="offer-card__info">
                                <strong>Безвозмездно</strong>
                                <p class="text-muted text-sm">Отдаю книгу в дар — ничего не предлагаю взамен</p>
                            </div>
                        </label>

                        @foreach (var b in Model.MyAvailableBooks)
                        {
                            <label class="offer-card">
                                <input type="radio" name="selectedOfferedBookId" value="@b.Id" />
                                <span class="offer-card__check"><svg class="icon"><use href="#i-check"/></svg></span>
                                @if (!string.IsNullOrEmpty(b.CoverImagePath))
                                {
                                    <img src="@b.CoverImagePath" alt="@b.Title" class="offer-card__cover" />
                                }
                                else
                                {
                                    <div class="offer-card__cover book-card__cover-placeholder">
                                        <svg class="icon"><use href="#i-book"/></svg>
                                    </div>
                                }
                                <div class="offer-card__info">
                                    <strong>@b.Title</strong>
                                    <p class="text-muted text-sm">@b.Author</p>
                                    <span class="chip chip--ok">@b.ConditionLabel</span>
                                </div>
                            </label>
                        }
                    </div>
                }
            </div>
        </div>

        <aside class="exchange-aside">
            <div class="panel exchange-summary">
                <h3 class="panel__title">Сводка обмена</h3>
                <div class="summary-row">
                    <span class="text-muted text-sm">Книги, которые получите:</span>
                    <strong class="summary-value">1</strong>
                </div>
                <div class="summary-row">
                    <span class="text-muted text-sm">Книга, которую отдадите:</span>
                    <strong class="summary-value" id="summary-offered">Безвозмездно</strong>
                </div>
                <button type="submit" class="btn btn-primary btn-lg w-full">
                    <svg class="icon"><use href="#i-swap"/></svg> Отправить предложение
                </button>
                <p class="text-muted text-xs" style="margin-top:var(--s-3);text-align:center;">
                    После отправки владелец книги получит уведомление и сможет принять или отклонить ваше предложение.
                </p>
            </div>
        </aside>
    </form>
</section>

@section Scripts {
    <script>
        document.querySelectorAll('input[name="selectedOfferedBookId"]').forEach(r => {
            r.addEventListener('change', () => {
                const label = r.closest('.offer-card')?.querySelector('.offer-card__info strong')?.textContent?.trim() || 'Безвозмездно';
                const el = document.getElementById('summary-offered');
                if (el) el.textContent = label;
            });
        });
    </script>
}
