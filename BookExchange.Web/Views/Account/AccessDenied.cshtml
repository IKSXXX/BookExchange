@{ ViewData["Title"] = "Доступ запрещён"; }

<div class="section--gray" style="padding:4rem 0; min-height:calc(100vh - 64px);">
    <div class="container">
        <div class="empty-state card" style="max-width:540px;margin:0 auto;">
            <svg class="icon" style="width:64px;height:64px;color:var(--red-600);"><use href="#i-shield"/></svg>
            <h2 class="mt-3 mb-2">Доступ запрещён</h2>
            <p class="text-muted mb-4">У вас нет прав на просмотр этой страницы.</p>
            <div class="flex gap-2 justify-center">
                <a href="/" class="btn btn-primary">
                    <svg class="icon"><use href="#i-home"/></svg>
                    На главную
                </a>
                <a asp-controller="Account" asp-action="Login" class="btn btn-outline">
                    <svg class="icon"><use href="#i-login"/></svg>
                    Войти
                </a>
            </div>
        </div>
    </div>
</div>
