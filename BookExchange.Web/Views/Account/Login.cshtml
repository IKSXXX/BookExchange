@model LoginViewModel
@{
    ViewData["Title"] = "Вход";
    Layout = "_Layout";
}

<div class="auth-wrap">
    <div class="auth-card">
        <div class="text-center mb-4">
            <div class="auth-logo">
                <svg class="icon"><use href="#i-book"/></svg>
            </div>
            <h1>С возвращением</h1>
            <p class="auth-card__sub">Войдите, чтобы продолжить обмены</p>
        </div>

        <form asp-action="Login" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="ReturnUrl" />
            <div asp-validation-summary="All" class="text-danger text-sm"></div>

            <div class="form-group">
                <label asp-for="Email" class="form-label">Email</label>
                <input asp-for="Email" type="email" autocomplete="email" class="form-input" placeholder="you@example.com" />
                <span asp-validation-for="Email" class="text-danger text-sm"></span>
            </div>
            <div class="form-group">
                <label asp-for="Password" class="form-label">Пароль</label>
                <input asp-for="Password" type="password" autocomplete="current-password" class="form-input" placeholder="••••••••" />
                <span asp-validation-for="Password" class="text-danger text-sm"></span>
            </div>
            <label class="checkbox-row">
                <input asp-for="RememberMe" type="checkbox" />
                <span>Запомнить меня</span>
            </label>

            <button type="submit" class="btn btn-primary btn-lg w-full mt-2">
                Войти
            </button>
        </form>

        <div class="auth-card__footer">
            Нет аккаунта? <a asp-action="Register">Зарегистрироваться</a>
        </div>

        <div class="auth-tip">
            <strong>Тестовые аккаунты</strong>
            <div><code>admin@bookswap.com</code> / <code>Admin123!</code></div>
            <div><code>anna@bookswap.com</code> / <code>Pass123!</code></div>
        </div>
    </div>
</div>
