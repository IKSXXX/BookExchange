@model LoginViewModel
@{ ViewData["Title"] = "Вход"; }

<section class="section">
    <div class="panel" style="max-width: 480px; margin: 2rem auto;">
        <h1>Вход</h1>
        <form asp-action="Login" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="ReturnUrl" />
            <div asp-validation-summary="All" class="text-danger"></div>

            <div class="form-group">
                <label asp-for="Email"></label>
                <input asp-for="Email" class="form-input" type="email" />
                <span asp-validation-for="Email" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Password">Пароль</label>
                <input asp-for="Password" class="form-input" type="password" />
                <span asp-validation-for="Password" class="text-danger"></span>
            </div>
            <label class="checkbox-label">
                <input asp-for="RememberMe" type="checkbox" /> @Html.DisplayNameFor(m => m.RememberMe)
            </label>
            <button class="btn btn-primary w-full" style="margin-top: 1rem;">Войти</button>
        </form>
        <p class="text-muted text-center" style="margin-top:1rem;">
            Нет аккаунта? <a asp-action="Register">Зарегистрироваться</a>
        </p>
        <div class="text-muted text-center" style="margin-top: 1rem; font-size: 0.85rem;">
            <strong>Тестовые аккаунты:</strong><br/>
            Админ: admin@bookswap.com / Admin123!<br/>
            Пользователь: anna@bookswap.com / Pass123!
        </div>
    </div>
</section>
