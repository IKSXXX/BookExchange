@model RegisterViewModel
@{
    ViewData["Title"] = "Регистрация";
    Layout = "_Layout";
}

<div class="auth-wrap">
    <div class="auth-card">
        <div class="text-center mb-4">
            <div class="auth-logo">
                <svg class="icon"><use href="#i-book"/></svg>
            </div>
            <h1>Создать аккаунт</h1>
            <p class="auth-card__sub">Присоединяйтесь к сообществу читателей</p>
        </div>

        <form asp-action="Register" method="post">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="All" class="text-danger text-sm"></div>

            <div class="form-group">
                <label asp-for="UserName" class="form-label">Имя пользователя</label>
                <input asp-for="UserName" autocomplete="username" class="form-input" />
                <span asp-validation-for="UserName" class="text-danger text-sm"></span>
            </div>
            <div class="form-group">
                <label asp-for="Email" class="form-label">Email</label>
                <input asp-for="Email" type="email" autocomplete="email" class="form-input" placeholder="you@example.com" />
                <span asp-validation-for="Email" class="text-danger text-sm"></span>
            </div>
            <div class="form-group">
                <label asp-for="Password" class="form-label">Пароль</label>
                <input asp-for="Password" type="password" autocomplete="new-password" class="form-input" />
                <span asp-validation-for="Password" class="text-danger text-sm"></span>
            </div>
            <div class="form-group">
                <label asp-for="ConfirmPassword" class="form-label">Подтверждение пароля</label>
                <input asp-for="ConfirmPassword" type="password" autocomplete="new-password" class="form-input" />
                <span asp-validation-for="ConfirmPassword" class="text-danger text-sm"></span>
            </div>

            <button type="submit" class="btn btn-primary btn-lg w-full mt-2">
                Создать аккаунт
            </button>
        </form>

        <div class="auth-card__footer">
            Уже есть аккаунт? <a asp-action="Login">Войти</a>
        </div>
    </div>
</div>
