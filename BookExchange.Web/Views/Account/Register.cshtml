@model RegisterViewModel
@{ ViewData["Title"] = "Регистрация"; }

<section class="section">
    <div class="panel" style="max-width: 480px; margin: 2rem auto;">
        <h1>Регистрация</h1>
        <form asp-action="Register" method="post">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="All" class="text-danger"></div>

            <div class="form-group">
                <label asp-for="UserName"></label>
                <input asp-for="UserName" class="form-input" />
                <span asp-validation-for="UserName" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Email"></label>
                <input asp-for="Email" class="form-input" type="email" />
                <span asp-validation-for="Email" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Password">Пароль</label>
                <input asp-for="Password" class="form-input" type="password" />
                <span asp-validation-for="Password" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="ConfirmPassword"></label>
                <input asp-for="ConfirmPassword" class="form-input" type="password" />
                <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
            </div>
            <button class="btn btn-primary w-full">Зарегистрироваться</button>
        </form>
        <p class="text-muted text-center" style="margin-top:1rem;">
            Уже есть аккаунт? <a asp-action="Login">Войти</a>
        </p>
    </div>
</section>
