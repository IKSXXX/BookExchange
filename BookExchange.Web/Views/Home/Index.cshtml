@model HomeViewModel
@inject SignInManager<User> SignInManager
@{
    ViewData["Title"] = "Главная";
}

<section class="hero">
    <div class="hero-inner">
        <span class="eyebrow">Добро пожаловать в BookSwap</span>
        <h1>Обменивайся <em>историями</em>, а не только книгами.</h1>
        <p>
            Сообщество читателей, где твоя полка превращается в библиотеку друзей.
            Предлагай книги на обмен, находи новые и знакомься с людьми, которые читают то, что любишь ты.
        </p>
        <div class="hero-actions">
            <a asp-controller="Book" asp-action="Index" class="btn btn-primary btn-lg">
                <svg class="icon"><use href="#i-search"/></svg> Открыть каталог
            </a>
            @if (!SignInManager.IsSignedIn(User))
            {
                <a asp-controller="Account" asp-action="Register" class="btn btn-outline btn-lg">
                    Создать аккаунт <svg class="icon"><use href="#i-arrow-right"/></svg>
                </a>
            }
            else
            {
                <a asp-controller="Book" asp-action="Create" class="btn btn-outline btn-lg">
                    <svg class="icon"><use href="#i-plus"/></svg> Добавить книгу
                </a>
            }
        </div>
    </div>
    <div class="hero-stack" aria-hidden="true">
        <span class="hero-stack__book"></span>
        <span class="hero-stack__book"></span>
        <span class="hero-stack__book"></span>
        <span class="hero-stack__book"></span>
        <span class="hero-stack__book"></span>
        <span class="hero-stack__book"></span>
    </div>
</section>

<section class="section">
    <div class="two-col">
        @* --- КНИГА ДНЯ --- *@
        <div class="panel">
            <span class="eyebrow">Книга дня</span>
            <h2 class="section-title">
                <svg class="icon"><use href="#i-bookmark"/></svg>
                Сегодня редакция рекомендует
            </h2>
            @if (Model.BookOfTheDay != null)
            {
                <div class="book-of-day">
                    <partial name="_BookCard" model="Model.BookOfTheDay" />
                </div>
            }
            else
            {
                <div class="empty">
                    <svg class="icon icon-xl"><use href="#i-bookmark"/></svg>
                    <p>Сегодня админ ещё не выбрал книгу дня.</p>
                </div>
            }
        </div>

        @* --- МИНИ-ИГРА --- *@
        <div class="panel">
            <span class="eyebrow">Мини-игра</span>
            <h2 class="section-title section-title--accent">
                <svg class="icon"><use href="#i-sparkles"/></svg>
                Угадай книгу по цитате
            </h2>
            <div id="quizWidget" data-initial='@Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.QuizQuestion))'>
                <p class="text-muted">Загрузка…</p>
            </div>
        </div>
    </div>
</section>

<section class="section">
    <div class="panel">
        <span class="eyebrow">AI-помощник</span>
        <h2 class="section-title section-title--accent">
            <svg class="icon"><use href="#i-sparkles"/></svg>
            Что почитать?
        </h2>
        <p class="text-muted" style="margin-bottom: 1rem;">
            Опиши, что хочешь почитать — и мы подберём книги из каталога.
            <em>(Это заглушка: поиск идёт по ключевым словам.)</em>
        </p>
        <form id="aiForm" class="flex gap-2" style="max-width: 780px;">
            <input name="query" type="text" class="form-input" placeholder="Например: фэнтези про магию" required />
            <button type="submit" class="btn btn-primary">
                <svg class="icon"><use href="#i-sparkles"/></svg> Подобрать
            </button>
        </form>
        <div id="aiResults" class="catalog-grid" style="margin-top: 1.5rem;"></div>
    </div>
</section>

<section class="section">
    <div class="flex items-center justify-between mb-3">
        <h2 class="section-title" style="margin: 0;">
            <svg class="icon"><use href="#i-sparkles"/></svg>
            Недавно добавленные
        </h2>
        <a asp-controller="Book" asp-action="Index" class="btn btn-ghost btn-sm">
            Все книги <svg class="icon"><use href="#i-arrow-right"/></svg>
        </a>
    </div>
    <div class="catalog-grid">
        @foreach (var b in Model.RecentBooks)
        {
            <partial name="_BookCard" model="b" />
        }
    </div>
</section>

@section Scripts {
    <script>
        // Quiz widget
        (function() {
            const widget = document.getElementById('quizWidget');
            if (!widget) return;
            let initial = null;
            try { initial = JSON.parse(widget.dataset.initial); } catch { }
            function render(q) {
                if (!q) {
                    widget.innerHTML = '<div class="empty"><p class="text-muted">Пока нет вопросов для игры.</p></div>';
                    return;
                }
                const opts = q.options.map(o =>
                    `<button type="button" class="quiz-option" data-ans="${o.replace(/"/g,'&quot;')}">${o}</button>`
                ).join('');
                widget.innerHTML = `
                    <div class="quiz-widget-card">
                        <blockquote class="quiz-quote">«${q.quote}»</blockquote>
                        <div class="quiz-options">${opts}</div>
                        <div class="quiz-result text-sm"></div>
                    </div>`;
                widget.querySelectorAll('.quiz-option').forEach(btn => {
                    btn.addEventListener('click', async () => {
                        const answer = btn.dataset.ans;
                        try {
                            const fd = new FormData();
                            fd.append('questionId', q.id);
                            fd.append('answer', answer);
                            const res = await fetch('/quiz/answer', { method: 'POST', body: fd });
                            const data = await res.json();
                            widget.querySelectorAll('.quiz-option').forEach(b => b.disabled = true);
                            if (data.isCorrect) {
                                btn.classList.add('correct');
                                widget.querySelector('.quiz-result').innerHTML = '<span class="chip chip--ok">✓ Верно!</span>';
                            } else {
                                btn.classList.add('wrong');
                                widget.querySelectorAll('.quiz-option').forEach(b => {
                                    if (b.dataset.ans === data.correctAnswer) b.classList.add('correct');
                                });
                                widget.querySelector('.quiz-result').innerHTML = '<span class="chip chip--danger">Верный ответ подсвечен зелёным</span>';
                            }
                            setTimeout(async () => {
                                const r = await fetch('/quiz/next');
                                if (r.ok) render(await r.json());
                            }, 2500);
                        } catch (e) { console.error(e); }
                    });
                });
            }
            render(initial);
        })();

        // AI form
        document.getElementById('aiForm')?.addEventListener('submit', async e => {
            e.preventDefault();
            const fd = new FormData();
            fd.append('query', e.target.query.value.trim());
            const res = await fetch('/ai/recommend', { method: 'POST', body: fd });
            const data = await res.json();
            const books = data.books || [];
            const box = document.getElementById('aiResults');
            if (!books.length) { box.innerHTML = '<div class="empty"><p>Ничего не нашлось. Попробуй другие слова.</p></div>'; return; }
            box.innerHTML = books.map(b => `
                <a class="book-card-link" href="/book/details/${b.id}">
                    <div class="book-card">
                        <div class="book-card__cover">
                            ${b.coverImagePath ? `<img src="${b.coverImagePath}" alt="${b.title}"/>` : '<div class="book-card__cover-placeholder">📖</div>'}
                        </div>
                        <div class="book-card__body">
                            <h3 class="book-card__title">${b.title}</h3>
                            <p class="book-card__author">${b.author}</p>
                            <div class="book-card__meta">
                                <span class="book-card__genre">${b.genre}</span>
                            </div>
                        </div>
                    </div>
                </a>`).join('');
        });
    </script>
}
