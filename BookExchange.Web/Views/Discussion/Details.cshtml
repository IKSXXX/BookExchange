@model DiscussionDetailsViewModel
@inject SignInManager<User> SignInManager
@{ ViewData["Title"] = Model.Title; }

<section class="section">
    <div class="page-header">
        <div>
            <a asp-controller="Book" asp-action="Details" asp-route-id="@Model.BookId" class="page-header__back">
                <svg class="icon"><use href="#i-arrow-left"/></svg> К книге «@Model.BookTitle»
            </a>
            <span class="eyebrow">Обсуждение</span>
            <h1>@Model.Title</h1>
            <p class="text-muted text-sm">Автор темы: @Model.AuthorName</p>
        </div>
    </div>

    <div class="panel chat-panel" style="max-height: 720px;">
        <div id="discMessages" class="chat-messages" data-discussion-id="@Model.Id">
            @if (Model.Messages.Count == 0)
            {
                <div class="empty" style="border:none;background:transparent;margin:auto;">
                    <svg class="icon icon-xl"><use href="#i-chat"/></svg>
                    <p class="text-muted">Пока тихо. Напиши первое сообщение!</p>
                </div>
            }
            else
            {
                foreach (var m in Model.Messages)
                {
                    <div class="chat-message">
                        @if (!string.IsNullOrEmpty(m.AvatarPath))
                        {
                            <img src="@m.AvatarPath" class="avatar avatar-sm" alt="" />
                        }
                        else
                        {
                            <span class="avatar avatar-sm" style="display:grid;place-items:center;background:var(--forest-soft);color:var(--forest);font-weight:700;font-size:.8rem;">@(m.UserName.Substring(0, 1).ToUpper())</span>
                        }
                        <div>
                            <strong>@m.UserName</strong>
                            <div class="chat-text">@m.Text</div>
                            <small>@m.CreatedAt.ToLocalTime().ToString("HH:mm · dd.MM")</small>
                        </div>
                    </div>
                }
            }
        </div>

        @if (SignInManager.IsSignedIn(User))
        {
            <form id="discForm" class="chat-form">
                <input type="text" id="discInput" placeholder="Напиши ответ..." maxlength="1000" autocomplete="off" />
                <button type="submit" class="btn btn-primary btn-icon" aria-label="Отправить">
                    <svg class="icon"><use href="#i-arrow-right"/></svg>
                </button>
            </form>
        }
        else
        {
            <div class="alert alert--info">
                <svg class="icon"><use href="#i-login"/></svg>
                <span>Чтобы писать в тему, <a asp-controller="Account" asp-action="Login">войди в аккаунт</a>.</span>
            </div>
        }
    </div>
</section>

@section Scripts {
    <script>
        (async () => {
            const box = document.getElementById('discMessages');
            const discId = parseInt(box.dataset.discussionId);
            box.scrollTop = box.scrollHeight;

            const conn = new signalR.HubConnectionBuilder().withUrl('/hubs/discussion').withAutomaticReconnect().build();
            conn.on('ReceiveMessage', m => {
                const empty = box.querySelector('.empty');
                if (empty) empty.remove();
                const el = document.createElement('div');
                el.className = 'chat-message';
                const avatar = m.avatarPath
                    ? `<img src="${m.avatarPath}" class="avatar avatar-sm" alt=""/>`
                    : `<span class="avatar avatar-sm" style="display:grid;place-items:center;background:var(--forest-soft);color:var(--forest);font-weight:700;font-size:.8rem;">${m.userName.charAt(0).toUpperCase()}</span>`;
                const d = new Date(m.createdAt);
                const time = d.toTimeString().slice(0,5) + ' · ' + d.toLocaleDateString();
                el.innerHTML = `${avatar}<div><strong>${m.userName}</strong><div class="chat-text"></div><small>${time}</small></div>`;
                el.querySelector('.chat-text').textContent = m.text;
                box.appendChild(el); box.scrollTop = box.scrollHeight;
            });
            try { await conn.start(); await conn.invoke('JoinDiscussion', discId); } catch (e) { console.error(e); }

            document.getElementById('discForm')?.addEventListener('submit', async e => {
                e.preventDefault();
                const input = document.getElementById('discInput');
                const text = input.value.trim();
                if (!text) return;
                try { await conn.invoke('SendMessage', discId, text); input.value = ''; } catch (err) { console.error(err); }
            });
        })();
    </script>
}
