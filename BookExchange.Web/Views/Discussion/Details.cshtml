@model DiscussionDetailsViewModel
@inject SignInManager<User> SignInManager
@{ ViewData["Title"] = Model.Title; }

<section class="section">
    <a asp-controller="Book" asp-action="Details" asp-route-id="@Model.BookId" class="btn btn-exchange">← К книге «@Model.BookTitle»</a>
    <h1 style="margin-top: 1rem;">@Model.Title</h1>
    <div class="text-muted">Автор темы: @Model.AuthorName</div>

    <div class="panel chat-panel" style="margin-top: 1.5rem;">
        <div id="discMessages" class="chat-messages" data-discussion-id="@Model.Id">
            @foreach (var m in Model.Messages)
            {
                <div class="chat-message">
                    @if (!string.IsNullOrEmpty(m.AvatarPath)) { <img src="@m.AvatarPath" class="avatar avatar-sm" /> }
                    <div>
                        <strong>@m.UserName</strong>
                        <div class="chat-text">@m.Text</div>
                        <small class="text-muted">@m.CreatedAt.ToLocalTime():HH:mm dd.MM</small>
                    </div>
                </div>
            }
        </div>

        @if (SignInManager.IsSignedIn(User))
        {
            <form id="discForm" class="chat-form">
                <input type="text" id="discInput" class="form-input" placeholder="Напиши ответ..." maxlength="1000" />
                <button type="submit" class="btn btn-primary">Отправить</button>
            </form>
        }
        else
        {
            <p class="text-muted">Чтобы писать в тему, <a asp-controller="Account" asp-action="Login">войди</a>.</p>
        }
    </div>
</section>

@section Scripts {
    <script>
        (async () => {
            const box = document.getElementById('discMessages');
            const discId = parseInt(box.dataset.discussionId);
            const conn = new signalR.HubConnectionBuilder().withUrl('/hubs/discussion').withAutomaticReconnect().build();
            conn.on('ReceiveMessage', m => {
                const el = document.createElement('div');
                el.className = 'chat-message';
                const avatar = m.avatarPath ? `<img src="${m.avatarPath}" class="avatar avatar-sm" />` : '';
                const d = new Date(m.createdAt);
                el.innerHTML = `${avatar}<div><strong>${m.userName}</strong><div class="chat-text"></div><small class="text-muted">${d.toLocaleTimeString().slice(0,5)} ${d.toLocaleDateString()}</small></div>`;
                el.querySelector('.chat-text').textContent = m.text;
                box.appendChild(el); box.scrollTop = box.scrollHeight;
            });
            try { await conn.start(); await conn.invoke('JoinDiscussion', discId); } catch (e) { console.error(e); }

            document.getElementById('discForm')?.addEventListener('submit', async e => {
                e.preventDefault();
                const input = document.getElementById('discInput');
                const text = input.value.trim();
                if (!text) return;
                try { await conn.invoke('SendMessage', discId, text); input.value = ''; } catch (err) { console.error(err); }
            });
        })();
    </script>
}
