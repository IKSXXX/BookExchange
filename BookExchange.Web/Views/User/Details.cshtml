@model UserProfileViewModel
@{ ViewData["Title"] = Model.UserName; }

<section class="section">
    <div class="profile-header">
        @if (!string.IsNullOrEmpty(Model.AvatarPath))
        {
            <img src="@Model.AvatarPath" class="avatar avatar-lg" />
        }
        <div>
            <h1>@Model.UserName</h1>
            <div class="text-muted">
                @if (!string.IsNullOrEmpty(Model.Location)) { <span>📍 @Model.Location &middot; </span> }
                ⭐ @Model.Rating.ToString("0.0") &middot;
                📚 @Model.BooksCount книг &middot;
                🔄 @Model.CompletedExchanges завершённых обменов &middot;
                зарегистрирован @Model.RegistrationDate.ToLocalTime().ToString("dd.MM.yyyy")
            </div>
            @if (Model.IsCurrentUser)
            {
                <div style="margin-top: 1rem;">
                    <a asp-controller="Account" asp-action="EditProfile" class="btn btn-exchange">Редактировать</a>
                    <a asp-controller="Book" asp-action="Create" class="btn btn-primary">+ Добавить книгу</a>
                </div>
            }
        </div>
    </div>

    <div class="tabs" style="margin-top: 2rem;">
        <div class="tabs-nav">
            <button class="tab-btn active" data-tab="books">Мои книги (@Model.MyBooks.Count)</button>
            <button class="tab-btn" data-tab="exchanges">Обмены (@Model.Exchanges.Count)</button>
            <button class="tab-btn" data-tab="favorites">Избранное (@Model.Favorites.Count)</button>
            <button class="tab-btn" data-tab="wishlist">Вишлист (@Model.Wishlist.Count)</button>
            <button class="tab-btn" data-tab="reviews">Отзывы</button>
        </div>

        <div class="tab-content" id="tab-books">
            @if (Model.MyBooks.Count == 0)
            {
                <div class="panel text-muted">Пусто. @(Model.IsCurrentUser ? "Добавь свою первую книгу!" : "")</div>
            }
            else
            {
                <div class="catalog-grid">
                    @foreach (var b in Model.MyBooks) { <partial name="_BookCard" model="b" /> }
                </div>
            }
        </div>

        <div class="tab-content" id="tab-exchanges" hidden>
            @if (Model.Exchanges.Count == 0)
            {
                <div class="panel text-muted">Пока нет обменов.</div>
            }
            else
            {
                <div class="panel">
                    <table class="table">
                        <thead><tr><th>Дата</th><th>Партнёр</th><th>Книги</th><th>Статус</th><th></th></tr></thead>
                        <tbody>
                        @foreach (var e in Model.Exchanges)
                        {
                            <tr>
                                <td>@e.CreatedAt.ToLocalTime().ToString("dd.MM.yy")</td>
                                <td>@e.OtherUserName</td>
                                <td>@e.BookRequestedTitle ⇄ @(e.BookOfferedTitle ?? "—")</td>
                                <td><span class="chip">@e.StatusLabel</span></td>
                                <td><a asp-controller="Exchange" asp-action="Details" asp-route-id="@e.Id" class="btn btn-exchange">Открыть</a></td>
                            </tr>
                        }
                        </tbody>
                    </table>
                </div>
            }
        </div>

        <div class="tab-content" id="tab-favorites" hidden>
            @if (Model.Favorites.Count == 0) { <div class="panel text-muted">Пусто.</div> }
            else { <div class="catalog-grid">@foreach (var b in Model.Favorites) { <partial name="_BookCard" model="b" /> }</div> }
        </div>

        <div class="tab-content" id="tab-wishlist" hidden>
            @if (Model.Wishlist.Count == 0) { <div class="panel text-muted">Пусто.</div> }
            else { <div class="catalog-grid">@foreach (var b in Model.Wishlist) { <partial name="_BookCard" model="b" /> }</div> }
        </div>

        <div class="tab-content" id="tab-reviews" hidden>
            <div class="two-col">
                <div class="panel">
                    <h3>Полученные (@Model.ReviewsReceived.Count)</h3>
                    @if (Model.ReviewsReceived.Count == 0) { <p class="text-muted">Пока нет отзывов.</p> }
                    @foreach (var r in Model.ReviewsReceived)
                    {
                        <div class="review-item">
                            <strong>@r.FromUserName</strong> — <span>@(new string('★', r.Rating))@(new string('☆', 5 - r.Rating))</span>
                            <p>@r.Comment</p>
                            <small class="text-muted">@r.CreatedAt.ToLocalTime():dd.MM.yyyy</small>
                        </div>
                    }
                </div>
                <div class="panel">
                    <h3>Оставленные (@Model.ReviewsGiven.Count)</h3>
                    @if (Model.ReviewsGiven.Count == 0) { <p class="text-muted">Пока пусто.</p> }
                    @foreach (var r in Model.ReviewsGiven)
                    {
                        <div class="review-item">
                            Для <strong>@r.ToUserName</strong> — @(new string('★', r.Rating))@(new string('☆', 5 - r.Rating))
                            <p>@r.Comment</p>
                            <small class="text-muted">@r.CreatedAt.ToLocalTime():dd.MM.yyyy</small>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</section>
