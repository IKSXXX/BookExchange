@model BookCatalogViewModel
@{
    ViewData["Title"] = "Каталог";
}

<section class="page-hero page-hero--green">
    <div class="page-hero__inner">
        <h1>Каталог книг</h1>
        <p>Найди свою следующую любимую книгу — всего <strong>@Model.Pagination.TotalItems</strong> изданий</p>
    </div>
</section>

<section class="section">
    <form id="catalogForm" method="get">
        <div class="catalog-search">
            <svg class="icon catalog-search__icon"><use href="#i-search"/></svg>
            <input type="text" name="search" value="@Model.SearchQuery" placeholder="Поиск по названию или автору..." />
        </div>

        <div class="catalog-layout">
        <aside class="catalog-filters">
            <div class="catalog-filters__head">
                <h3><svg class="icon"><use href="#i-menu"/></svg> Фильтры</h3>
                <a href="/catalog" class="link-reset">Сбросить</a>
            </div>

            <div class="filter-group">
                <label class="filter-label">Жанр</label>
                @foreach (var g in Model.AllGenres)
                {
                    var checkedAttr = Model.SelectedGenres.Contains(g) ? "checked" : null;
                    <label class="checkbox-label">
                        <input type="checkbox" name="genresArr" value="@g" @checkedAttr />
                        @g
                    </label>
                }
            </div>

            <div class="filter-group">
                <label class="filter-label">Состояние</label>
                @foreach (var c in Enum.GetValues<BookCondition>())
                {
                    var checkedAttr = Model.SelectedConditions.Contains(c) ? "checked" : null;
                    <label class="checkbox-label">
                        <input type="checkbox" name="conditionsArr" value="@c" @checkedAttr />
                        @MappingProfile.ConditionToLabel(c)
                    </label>
                }
            </div>

            <div class="filter-group">
                <label class="checkbox-label" style="font-weight: 600; color: var(--ink);">
                    <input type="checkbox" name="onlyAvailable" value="true" @(Model.OnlyAvailable ? "checked" : null) />
                    Только доступные
                </label>
            </div>

            <input type="hidden" name="genres" id="hiddenGenres" />
            <input type="hidden" name="conditions" id="hiddenConditions" />

            <button type="submit" class="btn btn-primary w-full">
                <svg class="icon"><use href="#i-check"/></svg> Применить
            </button>
        </aside>

        <div class="catalog-results">
            @if (Model.Books.Count == 0)
            {
                <div class="empty">
                    <svg class="icon icon-xl"><use href="#i-search"/></svg>
                    <h3>Ничего не найдено</h3>
                    <p>Попробуй изменить фильтры или сбросить их полностью.</p>
                </div>
            }
            else
            {
                <div class="catalog-grid">
                    @foreach (var b in Model.Books)
                    {
                        <partial name="_BookCard" model="b" />
                    }
                </div>

                @if (Model.Pagination.TotalPages > 1)
                {
                    <nav class="pagination">
                        @if (Model.Pagination.HasPrev)
                        {
                            <a class="btn btn-outline btn-sm" href="@Url.Action("Index", new { search = Model.SearchQuery, genres = string.Join(",", Model.SelectedGenres), conditions = string.Join(",", Model.SelectedConditions), onlyAvailable = Model.OnlyAvailable, page = Model.Pagination.Page - 1 })">
                                <svg class="icon"><use href="#i-arrow-left"/></svg> Назад
                            </a>
                        }
                        <span class="pagination-info">Страница @Model.Pagination.Page из @Model.Pagination.TotalPages</span>
                        @if (Model.Pagination.HasNext)
                        {
                            <a class="btn btn-outline btn-sm" href="@Url.Action("Index", new { search = Model.SearchQuery, genres = string.Join(",", Model.SelectedGenres), conditions = string.Join(",", Model.SelectedConditions), onlyAvailable = Model.OnlyAvailable, page = Model.Pagination.Page + 1 })">
                                Вперёд <svg class="icon"><use href="#i-arrow-right"/></svg>
                            </a>
                        }
                    </nav>
                }
            }
        </div>
        </div>
    </form>
</section>

@section Scripts {
    <script>
        document.getElementById('catalogForm').addEventListener('submit', e => {
            const genres = [...document.querySelectorAll('input[name="genresArr"]:checked')].map(c => c.value).join(',');
            const conditions = [...document.querySelectorAll('input[name="conditionsArr"]:checked')].map(c => c.value).join(',');
            document.getElementById('hiddenGenres').value = genres;
            document.getElementById('hiddenConditions').value = conditions;
            document.querySelectorAll('input[name="genresArr"]').forEach(c => c.removeAttribute('name'));
            document.querySelectorAll('input[name="conditionsArr"]').forEach(c => c.removeAttribute('name'));
        });
    </script>
}
