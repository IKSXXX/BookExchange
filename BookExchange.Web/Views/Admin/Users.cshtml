@model List<AdminUserListItemViewModel>
@{ ViewData["Title"] = "Пользователи"; }

<section class="section">
    <div class="page-header">
        <div>
            <a asp-action="Index" class="page-header__back">
                <svg class="icon"><use href="#i-arrow-left"/></svg> Админка
            </a>
            <span class="eyebrow">Модерация</span>
            <h1>Пользователи</h1>
        </div>
        <span class="text-muted text-sm">Всего: <strong>@Model.Count</strong></span>
    </div>

    <div class="panel panel--flush">
        <div class="table-wrap">
            <table class="table">
                <thead>
                    <tr>
                        <th>Имя</th>
                        <th>Email</th>
                        <th>Рейтинг</th>
                        <th>Книг</th>
                        <th>Регистрация</th>
                        <th>Статус</th>
                        <th>Действия</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var u in Model)
                    {
                        <tr>
                            <td><a asp-controller="User" asp-action="Details" asp-route-id="@u.Id" style="font-weight:600;color:var(--ink);">@u.UserName</a></td>
                            <td class="text-muted">@u.Email</td>
                            <td>
                                <svg class="icon" style="color:var(--mustard);"><use href="#i-star"/></svg>
                                @u.Rating.ToString("0.0")
                            </td>
                            <td>@u.BooksCount</td>
                            <td class="text-muted text-sm">@u.RegistrationDate.ToLocalTime().ToString("dd.MM.yyyy")</td>
                            <td>
                                @if (u.IsBlocked) { <span class="chip chip--danger">Заблокирован</span> } else { <span class="chip chip--ok">Активен</span> }
                                @if (u.IsAdmin) { <span class="badge badge--admin">Admin</span> }
                            </td>
                            <td>
                                <div class="flex gap-1 wrap">
                                    <form asp-action="ToggleBlock" method="post" class="inline-form">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@u.Id" />
                                        <button class="btn btn-outline btn-sm">
                                            @(u.IsBlocked ? "Разблокировать" : "Заблокировать")
                                        </button>
                                    </form>
                                    <form asp-action="ToggleAdmin" method="post" class="inline-form">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@u.Id" />
                                        <button class="btn btn-ghost btn-sm">
                                            @(u.IsAdmin ? "Снять Admin" : "Дать Admin")
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</section>
