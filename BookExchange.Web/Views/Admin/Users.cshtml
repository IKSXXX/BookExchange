@model List<AdminUserListItemViewModel>
@{ ViewData["Title"] = "Пользователи"; }

<section class="section">
    <h1>👥 Пользователи</h1>
    <a asp-action="Index" class="btn btn-exchange">← Назад</a>
    <div class="panel" style="margin-top: 1rem;">
        <table class="table">
            <thead>
                <tr><th>Имя</th><th>Email</th><th>Рейтинг</th><th>Книг</th><th>Регистрация</th><th>Статус</th><th>Действия</th></tr>
            </thead>
            <tbody>
                @foreach (var u in Model)
                {
                    <tr>
                        <td><a asp-controller="User" asp-action="Details" asp-route-id="@u.Id">@u.UserName</a></td>
                        <td>@u.Email</td>
                        <td>@u.Rating.ToString("0.0")</td>
                        <td>@u.BooksCount</td>
                        <td>@u.RegistrationDate.ToLocalTime().ToString("dd.MM.yyyy")</td>
                        <td>
                            @if (u.IsBlocked) { <span class="chip chip--danger">Заблокирован</span> } else { <span class="chip chip--ok">Активен</span> }
                            @if (u.IsAdmin) { <span class="chip">Admin</span> }
                        </td>
                        <td>
                            <form asp-action="ToggleBlock" method="post" class="inline-form">@Html.AntiForgeryToken()<input type="hidden" name="id" value="@u.Id" /><button class="btn btn-exchange">@(u.IsBlocked ? "Разблокировать" : "Блок")</button></form>
                            <form asp-action="ToggleAdmin" method="post" class="inline-form">@Html.AntiForgeryToken()<input type="hidden" name="id" value="@u.Id" /><button class="btn btn-exchange">@(u.IsAdmin ? "Снять Admin" : "Сделать Admin")</button></form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</section>
