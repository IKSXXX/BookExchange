@model SetBookOfDayViewModel
@{ ViewData["Title"] = "Книга дня"; }

<section class="section">
    <div class="page-header">
        <div>
            <a asp-action="Index" class="page-header__back">
                <svg class="icon"><use href="#i-arrow-left"/></svg> Админка
            </a>
            <span class="eyebrow">Подборка</span>
            <h1>Книга дня</h1>
        </div>
    </div>

    <div class="panel" style="max-width: 640px;">
        <form asp-action="BookOfTheDay" method="post">
            @Html.AntiForgeryToken()
            <div class="form-group">
                <label>Дата</label>
                <input type="date" name="date" value="@Model.Date.ToString("yyyy-MM-dd")" />
            </div>
            <div class="form-group">
                <label>Книга</label>
                <select name="bookId">
                    @foreach (var b in Model.AvailableBooks)
                    {
                        if (Model.CurrentBookOfDayId == b.Id)
                        {
                            <option value="@b.Id" selected>@b.Title — @b.Author</option>
                        }
                        else
                        {
                            <option value="@b.Id">@b.Title — @b.Author</option>
                        }
                    }
                </select>
            </div>
            <button class="btn btn-primary btn-lg">
                <svg class="icon"><use href="#i-check"/></svg> Сохранить
            </button>
        </form>
    </div>
</section>
