@model QuizQuestionFormViewModel
@{ ViewData["Title"] = "Новый вопрос"; }

<div class="section--gray" style="padding:2rem 0; min-height:calc(100vh - 64px);">
    <div class="container">
        <a asp-action="Quiz" class="btn btn-ghost btn-sm mb-6">
            <svg class="icon"><use href="#i-arrow-left"/></svg>
            К списку вопросов
        </a>

        <div class="form-wrap">
            <div class="mb-6">
                <h1 class="mb-2">Новый вопрос</h1>
                <p class="text-muted">Цитата из книги и 4 варианта ответа.</p>
            </div>

            <form asp-action="CreateQuiz" method="post">
                @Html.AntiForgeryToken()
                <div asp-validation-summary="All" class="text-danger text-sm mb-2"></div>

                <div class="card">
                    <div class="card-body stack">
                        <div class="form-group">
                            <label asp-for="BookId" class="form-label">Книга</label>
                            <select asp-for="BookId" class="form-input form-select">
                                @foreach (var b in Model.AvailableBooks) { <option value="@b.Id">@b.Title — @b.Author</option> }
                            </select>
                        </div>
                        <div class="form-group">
                            <label asp-for="Quote" class="form-label">Цитата</label>
                            <textarea asp-for="Quote" rows="3" class="form-input form-textarea" placeholder="Отрывок или цитата из книги..."></textarea>
                        </div>
                        <div class="form-group">
                            <label asp-for="CorrectAnswer" class="form-label">Правильный ответ</label>
                            <input asp-for="CorrectAnswer" class="form-input" />
                        </div>
                        <div class="form-row" style="grid-template-columns:1fr 1fr 1fr;">
                            <div class="form-group">
                                <label asp-for="Option2" class="form-label">Вариант 2</label>
                                <input asp-for="Option2" class="form-input" />
                            </div>
                            <div class="form-group">
                                <label asp-for="Option3" class="form-label">Вариант 3</label>
                                <input asp-for="Option3" class="form-input" />
                            </div>
                            <div class="form-group">
                                <label asp-for="Option4" class="form-label">Вариант 4</label>
                                <input asp-for="Option4" class="form-input" />
                            </div>
                        </div>
                    </div>
                </div>

                <div class="flex gap-2 mt-6">
                    <button type="submit" class="btn btn-primary btn-lg">
                        <svg class="icon"><use href="#i-check"/></svg>
                        Сохранить
                    </button>
                    <a asp-action="Quiz" class="btn btn-outline btn-lg">Отмена</a>
                </div>
            </form>
        </div>
    </div>
</div>
