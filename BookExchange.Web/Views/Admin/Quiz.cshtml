@model List<QuizQuestion>
@{ ViewData["Title"] = "Викторина"; }

<div class="section--gray" style="padding:2rem 0; min-height:calc(100vh - 64px);">
    <div class="container">
        <a asp-action="Index" class="btn btn-ghost btn-sm mb-4">
            <svg class="icon"><use href="#i-arrow-left"/></svg>
            В админку
        </a>

        <div class="flex items-center justify-between mb-6" style="flex-wrap:wrap;gap:1rem;">
            <div>
                <h1 class="mb-1">Вопросы викторины</h1>
                <p class="text-muted text-sm">Всего: <strong>@Model.Count</strong></p>
            </div>
            <a asp-action="CreateQuiz" class="btn btn-primary">
                <svg class="icon"><use href="#i-plus"/></svg>
                Добавить вопрос
            </a>
        </div>

        <div class="card">
            <div class="table-wrap" style="border:none;border-radius:0;">
                <table class="table">
                    <thead>
                        <tr>
                            <th>Цитата</th>
                            <th>Правильный ответ</th>
                            <th>Книга</th>
                            <th style="text-align:right;"></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var q in Model)
                        {
                            <tr>
                                <td style="max-width:420px;font-style:italic;color:var(--gray-600);">«@q.Quote»</td>
                                <td style="font-weight:600;">@q.CorrectAnswer</td>
                                <td class="text-muted">@(q.Book?.Title ?? "—")</td>
                                <td style="text-align:right;">
                                    <form asp-action="DeleteQuiz" method="post" style="margin:0;" onsubmit="return confirm('Удалить?');">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@q.Id" />
                                        <button class="btn btn-danger btn-sm">
                                            <svg class="icon"><use href="#i-trash"/></svg>
                                        </button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
