@model List<QuizQuestion>
@{ ViewData["Title"] = "Викторина"; }

<section class="section">
    <div class="page-header">
        <div>
            <a asp-action="Index" class="page-header__back">
                <svg class="icon"><use href="#i-arrow-left"/></svg> Админка
            </a>
            <span class="eyebrow">Викторина</span>
            <h1>Вопросы для игры</h1>
        </div>
        <a asp-action="CreateQuiz" class="btn btn-primary">
            <svg class="icon"><use href="#i-plus"/></svg> Добавить вопрос
        </a>
    </div>

    <div class="panel panel--flush">
        <div class="table-wrap">
            <table class="table">
                <thead>
                    <tr>
                        <th>Цитата</th>
                        <th>Правильный ответ</th>
                        <th>Книга</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var q in Model)
                    {
                        <tr>
                            <td style="max-width: 420px; font-style: italic; color: var(--muted);">«@q.Quote»</td>
                            <td style="font-weight: 600;">@q.CorrectAnswer</td>
                            <td class="text-muted">@(q.Book?.Title ?? "—")</td>
                            <td>
                                <form asp-action="DeleteQuiz" method="post" class="inline-form" onsubmit="return confirm('Удалить?');">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@q.Id" />
                                    <button class="btn btn-danger btn-sm">
                                        <svg class="icon"><use href="#i-trash"/></svg>
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</section>
