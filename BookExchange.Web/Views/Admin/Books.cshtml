@model List<Book>
@{ ViewData["Title"] = "Модерация книг"; }

<section class="section">
    <h1>📚 Книги</h1>
    <a asp-action="Index" class="btn btn-exchange">← Назад</a>
    <div class="panel" style="margin-top: 1rem;">
        <table class="table">
            <thead><tr><th>Название</th><th>Автор</th><th>Владелец</th><th>Жанр</th><th>Статус</th><th>Действия</th></tr></thead>
            <tbody>
                @foreach (var b in Model)
                {
                    <tr class="@(b.IsHidden ? "row-hidden" : "")">
                        <td><a asp-controller="Book" asp-action="Details" asp-route-id="@b.Id">@b.Title</a></td>
                        <td>@b.Author</td>
                        <td>@(b.Owner?.UserName ?? "")</td>
                        <td>@b.Genre</td>
                        <td>@(b.IsHidden ? "Скрыта" : (b.IsAvailable ? "Доступна" : "Занята"))</td>
                        <td>
                            <form asp-action="ToggleBookHidden" method="post" class="inline-form">@Html.AntiForgeryToken()<input type="hidden" name="id" value="@b.Id" /><button class="btn btn-exchange">@(b.IsHidden ? "Показать" : "Скрыть")</button></form>
                            <form asp-action="DeleteBook" method="post" class="inline-form" onsubmit="return confirm('Удалить навсегда?');">@Html.AntiForgeryToken()<input type="hidden" name="id" value="@b.Id" /><button class="btn btn-danger">Удалить</button></form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</section>
