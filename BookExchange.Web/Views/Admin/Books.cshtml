@model List<Book>
@{ ViewData["Title"] = "Модерация книг"; }

<section class="section">
    <div class="page-header">
        <div>
            <a asp-action="Index" class="page-header__back">
                <svg class="icon"><use href="#i-arrow-left"/></svg> Админка
            </a>
            <span class="eyebrow">Модерация</span>
            <h1>Книги</h1>
        </div>
        <span class="text-muted text-sm">Всего: <strong>@Model.Count</strong></span>
    </div>

    <div class="panel panel--flush">
        <div class="table-wrap">
            <table class="table">
                <thead>
                    <tr>
                        <th>Название</th>
                        <th>Автор</th>
                        <th>Владелец</th>
                        <th>Жанр</th>
                        <th>Статус</th>
                        <th>Действия</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var b in Model)
                    {
                        <tr class="@(b.IsHidden ? "row-hidden" : "")">
                            <td><a asp-controller="Book" asp-action="Details" asp-route-id="@b.Id" style="font-weight:600;color:var(--ink);">@b.Title</a></td>
                            <td class="text-muted">@b.Author</td>
                            <td class="text-muted">@(b.Owner?.UserName ?? "—")</td>
                            <td><span class="chip">@b.Genre</span></td>
                            <td>
                                @if (b.IsHidden)
                                {
                                    <span class="chip chip--danger">Скрыта</span>
                                }
                                else if (b.IsAvailable)
                                {
                                    <span class="chip chip--ok">Доступна</span>
                                }
                                else
                                {
                                    <span class="chip">Занята</span>
                                }
                            </td>
                            <td>
                                <div class="flex gap-1 wrap">
                                    <form asp-action="ToggleBookHidden" method="post" class="inline-form">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@b.Id" />
                                        <button class="btn btn-outline btn-sm">
                                            @(b.IsHidden ? "Показать" : "Скрыть")
                                        </button>
                                    </form>
                                    <form asp-action="DeleteBook" method="post" class="inline-form" onsubmit="return confirm('Удалить навсегда?');">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@b.Id" />
                                        <button class="btn btn-danger btn-sm">
                                            <svg class="icon"><use href="#i-trash"/></svg> Удалить
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</section>
