@model BookExchange.ViewModels.HomeViewModel
@{
    ViewData["Title"] = "Главная";
}

<!-- КАРУСЕЛЬ (слайдер) -->
<section class="hero-carousel">
    <div class="carousel-container">
        <div class="carousel-slides" id="carouselSlides">
            <div class="carousel-slide" style="background: linear-gradient(135deg, #1e3c2c, #2e7d32);">
                <div class="carousel-content">
                    <span class="carousel-badge">🔥 Книга недели</span>
                    <h2>«Преступление и наказание»</h2>
                    <p>Ф. Достоевский — классика, которая вдохновляет уже 150 лет. Обменяй прямо сейчас!</p>
                    <a href="/book/1" class="carousel-btn">Подробнее →</a>
                </div>
            </div>
            <div class="carousel-slide" style="background: linear-gradient(135deg, #2c3e50, #1a252f);">
                <div class="carousel-content">
                    <span class="carousel-badge">📚 Новинки сезона</span>
                    <h2>Свежие поступления</h2>
                    <p>Добавлены десятки книг современных авторов. Найди свою следующую любимую книгу!</p>
                    <a href="/catalog" class="carousel-btn">Смотреть новинки →</a>
                </div>
            </div>
            <div class="carousel-slide" style="background: linear-gradient(135deg, #8B4513, #A0522D);">
                <div class="carousel-content">
                    <span class="carousel-badge">⭐ Топ обменов</span>
                    <h2>Самые популярные книги</h2>
                    <p>1984, Мастер и Маргарита, Война и мир — их ищут чаще всего. Успей предложить обмен!</p>
                    <a href="/catalog?sort=popular" class="carousel-btn">В топ →</a>
                </div>
            </div>
        </div>
        <button class="carousel-btn-prev" id="carouselPrev">❮</button>
        <button class="carousel-btn-next" id="carouselNext">❯</button>
        <div class="carousel-dots" id="carouselDots"></div>
    </div>
</section>

<!-- ОСНОВНОЙ ГЕРО (был ранее) -->
<section class="hero-section">
    <div class="container">
        <div class="hero-badge">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#FF8C42" stroke-width="2">
                <path d="M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z" />
            </svg>
            <span>Некоммерческий проект для любителей книг</span>
        </div>

        <h1 class="hero-title">
            Обменивайся книгами<br>
            <span class="hero-highlight">с радостью!</span>
        </h1>

        <p class="hero-description">
            Присоединяйся к сообществу читателей. Дари книгам вторую жизнь, находи новые истории и делись любимыми произведениями!
        </p>

        <div class="hero-buttons">
            <a href="/catalog" class="btn btn-primary btn-large">
                Найти книгу
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M9 5l7 7-7 7" />
                </svg>
            </a>
            <a href="/profile" class="btn btn-secondary btn-large">
                Добавить книги
            </a>
        </div>

        <div class="stats-grid">
            <div class="stat-item">
                <div class="stat-number">2,500+</div>
                <div class="stat-label">книг</div>
            </div>
            <div class="stat-divider"></div>
            <div class="stat-item">
                <div class="stat-number">850+</div>
                <div class="stat-label">читателей</div>
            </div>
            <div class="stat-divider"></div>
            <div class="stat-item">
                <div class="stat-number">1,200+</div>
                <div class="stat-label">обменов</div>
            </div>
        </div>
    </div>
</section>

<!-- Как это работает -->
<section class="how-it-works">
    <div class="container">
        <div class="section-header">
            <h2>Как начать обмениваться?</h2>
            <p>Три простых шага к новым книгам и новым знакомствам</p>
        </div>
        <div class="steps-grid">
            <div class="step-card">
                <div class="step-number">1</div>
                <div class="step-icon">📚</div>
                <h3>Добавьте свои книги</h3>
                <p>Загрузите фото и описание книг, которыми готовы поделиться</p>
            </div>
            <div class="step-card">
                <div class="step-number">2</div>
                <div class="step-icon">🔍</div>
                <h3>Найдите интересующую</h3>
                <p>Используйте поиск и фильтры, чтобы найти книгу мечты</p>
            </div>
            <div class="step-card">
                <div class="step-number">3</div>
                <div class="step-icon">🤝</div>
                <h3>Предложите обмен</h3>
                <p>Договоритесь с владельцем и отправляйте книги друг другу</p>
            </div>
        </div>
    </div>
</section>

