<!-- Недавно добавленные книги -->
<section class="recent-books-section">
    <div class="container">
        <div class="section-header with-link">
            <div>
                <h2>Недавно добавленные книги</h2>
                <p>Свежие поступления от наших читателей</p>
            </div>
            <a href="/catalog" class="view-all-link">Смотреть все →</a>
        </div>
        <div class="recent-books-grid">
            @foreach (var book in Model.RecentBooks)
            {
                <a href="/book/@book.Id" class="recent-book-card">
                    <img src="@book.CoverUrl" alt="@book.Title" class="recent-book-img" />
                    <div class="recent-book-info">
                        <h3 class="recent-book-title">@book.Title</h3>
                        <p class="recent-book-author">@book.Author</p>
                        <div class="recent-book-tags">
                            <span class="tag-genre">@book.Genre</span>
                            <span class="tag-condition">@book.Condition</span>
                        </div>
                    </div>
                </a>
            }
        </div>
        <div class="mobile-view-all">
            <a href="/catalog" class="view-all-link">Смотреть все →</a>
        </div>
    </div>
</section>

