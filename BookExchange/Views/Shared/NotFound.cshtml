@{
    ViewData["Title"] = "Страница не найдена";
}

<div class="min-h-screen flex items-center justify-center bg-gradient-to-b from-[#FFFBF5] to-white">
    <div class="text-center px-4">
        <div class="mb-8">
            <div class="text-9xl font-bold bg-gradient-to-r from-[#4CAF50] to-[#8BC34A] bg-clip-text text-transparent mb-4">
                404
            </div>
            <h1 class="text-4xl font-bold text-[#2C3E50] mb-4">
                Страница не найдена
            </h1>
            <p class="text-lg text-[#7F8C8D] max-w-md mx-auto mb-8">
                Кажется, вы заблудились. Эта страница не существует или была перемещена.
            </p>
        </div>

        <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
            <a href="/" class="flex items-center gap-2 bg-gradient-to-r from-[#4CAF50] to-[#8BC34A] text-white px-8 py-4 rounded-xl font-bold shadow-xl shadow-green-500/30 hover:shadow-2xl hover:scale-105 transition-all">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" /></svg>
                На главную
            </a>

            <a href="/catalog" class="flex items-center gap-2 bg-white text-[#2C3E50] border-2 border-[#4CAF50] px-8 py-4 rounded-xl font-bold shadow-lg hover:bg-[#F0F8F0] transition-all hover:scale-105">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" /></svg>
                К каталогу
            </a>
        </div>
    </div>
</div>