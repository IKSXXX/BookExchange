@model BookExchange.ViewModels.BookCardViewModel

<a href="/book/@Model.Id" class="book-card group">
    @if (!Model.IsAvailable)
    {
        <div class="absolute top-3 left-3 z-10 bg-[#E67E22] text-white text-xs font-bold px-3 py-1 rounded-full shadow-lg">
            Недоступна
        </div>
    }
    <img src="@Model.CoverUrl" alt="@Model.Title" class="book-card-img" />
    <div class="book-card-body">
        <h3 class="book-title group-hover:text-green transition-colors">
            @Model.Title
        </h3>
        <p class="book-author">@Model.Author</p>
        <div class="book-meta">
            <span class="text-xs font-semibold px-3 py-1 bg-[#F0F8F0] text-[#4CAF50] rounded-full">
                @Model.Genre
            </span>
            <span class="text-xs text-[#7F8C8D] capitalize">@Model.Condition</span>
        </div>
        <div class="book-owner">
            <img src="@Model.Owner.Avatar" alt="@Model.Owner.Name" class="w-6 h-6 rounded-full object-cover" />
            <span class="text-xs text-[#7F8C8D]">@Model.Owner.Name</span>
        </div>
    </div>
</a>