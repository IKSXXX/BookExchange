@model BookExchange.ViewModels.BookCatalogViewModel
@{
    ViewData["Title"] = "Каталог книг";
}

<div class="min-h-screen bg-gradient-to-b from-[#FFFBF5] to-white">
    <div class="bg-gradient-to-r from-[#4CAF50] to-[#8BC34A] text-white py-12">
        <div class="catalog-wrapper">
            <h1 class="text-4xl font-bold mb-4">Каталог книг</h1>
            <p class="text-lg opacity-90">Найди свою следующую любимую книгу</p>
        </div>
    </div>

    <div class="catalog-wrapper py-8">
        <!-- Поиск -->
        <div class="mb-6">
            <div class="relative max-w-2xl">
                <svg class="absolute left-4 top-1/2 -translate-y-1/2 w-5 h-5 text-[#7F8C8D]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
                </svg>
                <form method="get" id="filterForm" action="/catalog">
                    <input type="text" name="search" placeholder="Поиск по названию или автору..."
                           value="@Model.SearchQuery"
                           class="w-full pl-12 pr-4 py-4 rounded-xl border-2 border-[#E0E0E0] focus:border-[#4CAF50] outline-none bg-white shadow-sm transition-all" />
                    <input type="hidden" name="page" id="pageInput" value="1" />
                </form>
            </div>
        </div>

        <div class="catalog-layout">
            <!-- Фильтры (sidebar) -->
            <aside class="filter-sidebar">
                <div class="bg-white rounded-2xl p-6 border-2 border-[#E0E0E0] sticky top-24">
                    <div class="flex items-center justify-between mb-6">
                        <div class="flex items-center gap-2">
                            <svg class="w-5 h-5 text-[#4CAF50]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 4a1 1 0 011-1h16a1 1 0 011 1v2.586a1 1 0 01-.293.707l-6.414 6.414a1 1 0 00-.293.707V17l-4 4v-6.586a1 1 0 00-.293-.707L3.293 7.293A1 1 0 013 6.586V4z" />
                            </svg>
                            <h2 class="font-bold text-[#2C3E50]">Фильтры</h2>
                        </div>
                        @if (Model.HasActiveFilters)
                        {
                            <button type="button" id="clearFiltersBtn" class="text-sm text-[#E67E22] hover:text-[#FF8C42] font-semibold flex items-center gap-1">
                                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" /></svg>
                                Сбросить
                            </button>
                        }
                    </div>

                    <div class="space-y-6">
                        <!-- Жанры -->
                        <div>
                            <h3 class="font-semibold text-[#2C3E50] mb-3">Жанр</h3>
                            <div class="space-y-2" id="genresList">
                                @foreach (var genre in Model.AllGenres)
                                {
                                    <label class="flex items-center gap-2 cursor-pointer group">
                                        <input type="checkbox" value="@genre" class="genre-checkbox w-5 h-5 rounded border-2 border-[#E0E0E0] text-[#4CAF50] focus:ring-[#4CAF50] focus:ring-offset-0 cursor-pointer"
                                        @(Model.SelectedGenres.Contains(genre) ? "checked" : "") />
                                        <span class="text-sm text-[#2C3E50] group-hover:text-[#4CAF50] transition-colors">@genre</span>
                                    </label>
                                }
                            </div>
                        </div>

                        <!-- Состояние -->
                        <div class="pt-4 border-t border-[#E0E0E0]">
                            <h3 class="font-semibold text-[#2C3E50] mb-3">Состояние</h3>
                            <div class="space-y-2" id="conditionsList">
                                @foreach (var condition in Model.AllConditions)
                                {
                                    <label class="flex items-center gap-2 cursor-pointer group">
                                        <input type="checkbox" value="@condition" class="condition-checkbox w-5 h-5 rounded border-2 border-[#E0E0E0] text-[#4CAF50] focus:ring-[#4CAF50] focus:ring-offset-0 cursor-pointer"
                                        @(Model.SelectedConditions.Contains(condition) ? "checked" : "") />
                                        <span class="text-sm text-[#2C3E50] group-hover:text-[#4CAF50] transition-colors capitalize">@condition</span>
                                    </label>
                                }
                            </div>
                        </div>

                        <!-- Только доступные -->
                        <div class="pt-4 border-t border-[#E0E0E0]">
                            <label class="flex items-center gap-2 cursor-pointer group">
                                <input type="checkbox" id="onlyAvailableCheckbox" class="w-5 h-5 rounded border-2 border-[#E0E0E0] text-[#4CAF50] focus:ring-[#4CAF50] focus:ring-offset-0 cursor-pointer"
                                @(Model.ShowOnlyAvailable ? "checked" : "") />
                                <span class="text-sm text-[#2C3E50] group-hover:text-[#4CAF50] transition-colors font-semibold">Только доступные</span>
                            </label>
                        </div>
                    </div>
                </div>
            </aside>

            <!-- Результаты -->
            <div style="flex:1">
                <div class="mb-4 flex items-center justify-between">
                    <p class="text-[#7F8C8D]">
                        Найдено книг: <span class="font-bold text-[#4CAF50]">@Model.Pagination.TotalItems</span>
                    </p>
                </div>

                @if (Model.Books.Count == 0)
                {
                    <div class="bg-white rounded-2xl p-12 text-center border-2 border-dashed border-[#E0E0E0]">
                        <div class="w-20 h-20 bg-[#F0F8F0] rounded-full flex items-center justify-center mx-auto mb-4">
                            <svg class="w-10 h-10 text-[#4CAF50]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" /></svg>
                        </div>
                        <h3 class="text-xl font-bold text-[#2C3E50] mb-2">Книги не найдены</h3>
                        <p class="text-[#7F8C8D] mb-4">Попробуйте изменить параметры поиска</p>
                        <button type="button" id="clearFiltersBtn2" class="text-[#4CAF50] font-semibold hover:text-[#388E3C]">Сбросить фильтры</button>
                    </div>
                }
                else
                {
                    <div class="catalog-grid">
                        @foreach (var book in Model.Books)
                        {
                            <partial name="_BookCard" model="book" />
                        }
                    </div>
                }

                <!-- Пагинация -->
                @if (Model.Pagination.TotalPages > 1)
                {
                    <div class="flex justify-center items-center gap-2 mt-8 flex-wrap">
                        @if (Model.Pagination.CurrentPage > 1)
                        {
                            <a href="#" class="page-link px-4 py-2 rounded-xl border border-[#E0E0E0] text-[#4CAF50] hover:bg-[#F0F8F0] transition" data-page="@(Model.Pagination.CurrentPage - 1)">← Назад</a>
                        }
                        @for (int i = 1; i <= Model.Pagination.TotalPages; i++)
                        {
                            if (i == Model.Pagination.CurrentPage)
                            {
                                <span class="px-4 py-2 rounded-xl bg-[#4CAF50] text-white">@i</span>
                            }
                            else
                            {
                                <a href="#" class="page-link px-4 py-2 rounded-xl border border-[#E0E0E0] text-[#2C3E50] hover:bg-[#F0F8F0] transition" data-page="@i">@i</a>
                            }
                        }
                        @if (Model.Pagination.CurrentPage < Model.Pagination.TotalPages)
                        {
                            <a href="#" class="page-link px-4 py-2 rounded-xl border border-[#E0E0E0] text-[#4CAF50] hover:bg-[#F0F8F0] transition" data-page="@(Model.Pagination.CurrentPage + 1)">Вперёд →</a>
                        }
                    </div>
                }
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        const form = document.getElementById('filterForm');
        const searchInput = document.querySelector('input[name="search"]');
        const genreCheckboxes = document.querySelectorAll('.genre-checkbox');
        const conditionCheckboxes = document.querySelectorAll('.condition-checkbox');
        const onlyAvailableCheckbox = document.getElementById('onlyAvailableCheckbox');
        const pageInput = document.getElementById('pageInput');

        function submitFilters(page = 1) {
            const params = new URLSearchParams();
            if (searchInput.value) params.set('search', searchInput.value);
            genreCheckboxes.forEach(cb => {
                if (cb.checked) params.append('genreIds', cb.value);
            });
            conditionCheckboxes.forEach(cb => {
                if (cb.checked) params.append('conditionNames', cb.value);
            });
            if (onlyAvailableCheckbox.checked) params.set('showOnlyAvailable', 'true');
            params.set('page', page);
            window.location.href = '/catalog?' + params.toString();
        }

        searchInput.addEventListener('input', debounce(() => submitFilters(1), 500));
        genreCheckboxes.forEach(cb => cb.addEventListener('change', () => submitFilters(1)));
        conditionCheckboxes.forEach(cb => cb.addEventListener('change', () => submitFilters(1)));
        onlyAvailableCheckbox.addEventListener('change', () => submitFilters(1));

        function debounce(func, wait) {
            let timeout;
            return function() {
                clearTimeout(timeout);
                timeout = setTimeout(() => func.apply(this, arguments), wait);
            };
        }

        function clearFilters() {
            searchInput.value = '';
            genreCheckboxes.forEach(cb => cb.checked = false);
            conditionCheckboxes.forEach(cb => cb.checked = false);
            onlyAvailableCheckbox.checked = false;
            submitFilters(1);
        }

        document.querySelectorAll('#clearFiltersBtn, #clearFiltersBtn2').forEach(btn => {
            btn.addEventListener('click', clearFilters);
        });

        document.querySelectorAll('.page-link').forEach(link => {
            link.addEventListener('click', function(e) {
                e.preventDefault();
                const page = this.dataset.page;
                if (page) submitFilters(parseInt(page));
            });
        });
    </script>
}